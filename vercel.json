{
  "version": 2,
  "name": "consulta360-cristiane",
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.js" },
    { "src": "/api/config", "dest": "/api/config.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
